@model IEnumerable<Biljkovoditelj.model.Entities.Room>

@{
    ViewData["Title"] = "Rooms";
}

<div class="entity-header">
    <h1>🏠 Rooms</h1>
    <p>Manage your plant rooms and their conditions</p>
</div>

<div class="entity-grid">
    @foreach (var room in Model)
    {
        <div class="entity-card">
            <div class="entity-card-header">
                <h3>@room.Name</h3>
                <span class="entity-id">#@room.Id</span>
            </div>
            <div class="entity-card-content">
                <div class="entity-stat">
                    <span class="stat-label">Light Level:</span>
                    <span class="stat-value">@room.LightLevel</span>
                </div>
                <div class="entity-stat">
                    <span class="stat-label">Humidity:</span>
                    <span class="stat-value">@room.Humidity%</span>
                </div>
                <div class="entity-stat">
                    <span class="stat-label">Temperature:</span>
                    <span class="stat-value">@room.Temperature°C</span>
                </div>
                <div class="entity-stat">
                    <span class="stat-label">Plants:</span>
                    <span class="stat-value">@room.Plants.Count</span>
                </div>
            </div>
            <div class="entity-card-actions">
                <a href="/Rooms/Details/@room.Id" class="btn-details">View Details</a>
            </div>
        </div>
    }
</div>

<div class="back-link">
    <a href="/">← Back to Dashboard</a>
</div>