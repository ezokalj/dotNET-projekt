@model Biljkovoditelj.model.Entities.Room

@{
    ViewData["Title"] = $"Room - @Model.Name";
}

<div class="entity-detail">
    <div class="entity-detail-header">
        <h1>🏠 @Model.Name</h1>
        <span class="entity-id">#@Model.Id</span>
    </div>

    <div class="detail-grid">
        <div class="detail-card">
            <h3>Room Conditions</h3>
            <div class="detail-stats">
                <div class="detail-stat">
                    <span class="stat-label">Light Level:</span>
                    <span class="stat-value">@Model.LightLevel</span>
                </div>
                <div class="detail-stat">
                    <span class="stat-label">Humidity:</span>
                    <span class="stat-value">@Model.Humidity%</span>
                </div>
                <div class="detail-stat">
                    <span class="stat-label">Temperature:</span>
                    <span class="stat-value">@Model.Temperature°C</span>
                </div>
            </div>
        </div>

        <div class="detail-card">
            <h3>Plants in this Room (@Model.Plants.Count)</h3>
            @if (Model.Plants.Any())
            {
                <div class="plants-list">
                    @foreach (var plant in Model.Plants)
                    {
                        <div class="plant-item">
                            <div class="plant-info">
                                <strong>@plant.Name</strong>
                                <span class="plant-species">@plant.Species</span>
                            </div>
                            <a href="/Plants/Details/@plant.Id" class="plant-link">View Plant</a>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="empty-state">No plants in this room</p>
            }
        </div>
    </div>

    <div class="back-link">
        <a href="/Rooms">← Back to Rooms</a>
    </div>
</div>