@model IEnumerable<Biljkovoditelj.model.Entities.User>

@{
    ViewData["Title"] = "Users";
}

<div class="entity-header">
    <h1>👥 Users</h1>
    <p>Plant care enthusiasts and their collections</p>
</div>

<div class="entity-grid">
    @foreach (var user in Model)
    {
        <div class="entity-card">
            <div class="entity-card-header">
                <h3>@user.Name</h3>
                <span class="entity-id">#@user.Id</span>
            </div>
            <div class="entity-card-content">
                <div class="entity-stat">
                    <span class="stat-label">Email:</span>
                    <span class="stat-value">@user.Email</span>
                </div>
                <div class="entity-stat">
                    <span class="stat-label">Plants:</span>
                    <span class="stat-value">@user.Plants.Count</span>
                </div>
            </div>
            <div class="entity-card-actions">
                <a href="/Users/Details/@user.Id" class="btn-details">View Details</a>
            </div>
        </div>
    }
</div>

<div class="back-link">
    <a href="/">← Back to Dashboard</a>
</div>