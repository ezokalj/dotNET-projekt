@model Biljkovoditelj.model.Entities.User

@{
    ViewData["Title"] = $"User - @Model.Name";
}

<div class="entity-detail">
    <div class="entity-detail-header">
        <h1>👥 @Model.Name</h1>
        <span class="entity-id">#@Model.Id</span>
    </div>

    <div class="detail-grid">
        <div class="detail-card">
            <h3>User Information</h3>
            <div class="detail-stats">
                <div class="detail-stat">
                    <span class="stat-label">Name:</span>
                    <span class="stat-value">@Model.Name</span>
                </div>
                <div class="detail-stat">
                    <span class="stat-label">Email:</span>
                    <span class="stat-value">@Model.email</span>
                </div>
            </div>
        </div>

        <div class="detail-card">
            <h3>Plants Collection (@Model.Plants.Count)</h3>
            @if (Model.Plants.Any())
            {
                <div class="plants-list">
                    @foreach (var plant in Model.Plants)
                    {
                        <div class="plant-item">
                            <div class="plant-info">
                                <strong>@plant.Name</strong>
                                <span class="plant-species">@plant.Species</span>
                            </div>
                            <a href="/Plants/Details/@plant.Id" class="plant-link">View Plant</a>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="empty-state">No plants in collection</p>
            }
        </div>
    </div>

    <div class="back-link">
        <a href="/Users">← Back to Users</a>
    </div>
</div>