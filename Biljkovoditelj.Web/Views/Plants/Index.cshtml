@model List<Biljkovoditelj.model.Entities.Plant>

@{
    ViewData["Title"] = "Plants";
}

<div class="entity-header">
    <h1>🌱 Plants</h1>
    <p>Your plant collection and care information</p>
</div>

<div class="entity-grid">
    @foreach (var plant in Model)
    {
        <div class="entity-card">
            <div class="entity-card-header">
                <h3>@plant.Name</h3>
                <span class="entity-id">#@plant.Id</span>
            </div>
            <div class="entity-card-content">
                <div class="entity-stat">
                    <span class="stat-label">Species:</span>
                    <span class="stat-value">@plant.Species</span>
                </div>
                <div class="entity-stat">
                    <span class="stat-label">Age:</span>
                    <span class="stat-value">@plant.Age years</span>
                </div>
                <div class="entity-stat">
                    <span class="stat-label">Watering Interval:</span>
                    <span class="stat-value">@plant.WateringIntervalDays days</span>
                </div>
                <div class="entity-stat">
                    <span class="stat-label">Last Watered:</span>
                    <span class="stat-value">@plant.LastWatered.ToString("MMM dd")</span>
                </div>
                <div class="entity-stat">
                    <span class="stat-label">Health:</span>
                    <span class="stat-value">@plant.HealthStatus</span>
                </div>
            </div>
            <div class="entity-card-actions">
                <a href="/Plants/Details/@plant.Id" class="btn-details">View Details</a>
            </div>
        </div>
    }
</div>

<div class="back-link">
    <a href="/">← Back to Dashboard</a>
</div>