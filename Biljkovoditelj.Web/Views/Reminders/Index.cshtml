@model IEnumerable<Biljkovoditelj.model.Entities.Reminder>

@{
    ViewData["Title"] = "Reminders";
}

<div class="entity-header">
    <h1>🔔 Reminders</h1>
    <p>Plant care reminders and notifications</p>
</div>

<div class="entity-grid">
    @foreach (var reminder in Model)
    {
        <div class="entity-card">
            <div class="entity-card-header">
                <h3>@reminder.Message</h3>
                <span class="entity-id">#@reminder.Id</span>
            </div>
            <div class="entity-card-content">
                <div class="entity-stat">
                    <span class="stat-label">Reminder Date:</span>
                    <span class="stat-value">@reminder.ReminderDate.ToString("MMM dd, yyyy HH:mm")</span>
                </div>
                <div class="entity-stat">
                    <span class="stat-label">Plant ID:</span>
                    <span class="stat-value">@reminder.PlantId</span>
                </div>
            </div>
            <div class="entity-card-actions">
                <a href="/Reminders/Details/@reminder.Id" class="btn-details">View Details</a>
            </div>
        </div>
    }
</div>

<div class="back-link">
    <a href="/">← Back to Dashboard</a>
</div>